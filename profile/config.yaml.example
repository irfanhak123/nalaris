1|# =============================================================================
2|# Hermes Profile: Project Nalaris — Personal Assistant
3|# =============================================================================
4|# Copy this file to config.yaml and fill in your values.
5|# Run: cp config.yaml.example config.yaml && nano config.yaml
6|# =============================================================================
7|
8|# --- Provider Settings -------------------------------------------------------
9|# Your LLM provider. Hermes supports OpenAI-compatible APIs.
10|provider:
11|  type: openai-compatible
12|  base_url: https://api.openai.com/v1          # Change to your provider's URL
13|  api_key: ${OPENAI_API_KEY}                     # Or paste your key directly
14|  # api_key: sk-...                              # Alternative: hardcode (less secure)
15|
16|# --- Model Settings ----------------------------------------------------------
17|model:
18|  name: gpt-4o                                   # Your model name
19|  temperature: 0.7                               # 0.0 = deterministic, 1.0 = creative
20|  max_tokens: 4096                               # Max output tokens per response
21|
22|# --- Profile Settings --------------------------------------------------------
23|profile:
24|  name: nalaris                                    # Profile name (used by Hermes)
25|  timezone: Asia/Jakarta                         # Your timezone (IANA format)
26|  time_format: "HH.MM"                           # 24-hour dot-separated format
27|
28|# --- Enabled Toolsets --------------------------------------------------------
29|# These are the toolsets the personal assistant can use.
30|# Uncomment or comment to enable/disable.
31|toolsets:
32|  - name: calendar                               # Read calendar events
33|    enabled: true
34|  - name: gmail                                  # Read emails (optional)
35|    enabled: false
36|  - name: obsidian                               # Read/write to Obsidian vault
37|    enabled: true
38|  - name: shell                                  # Execute shell commands
39|    enabled: true
40|  - name: web_search                             # Search the web
41|    enabled: false
42|  - name: file_read                              # Read files from disk
43|    enabled: true
44|  - name: file_write                             # Write files to disk
45|    enabled: true
46|
47|# --- Cron Schedule -----------------------------------------------------------
48|# The personal assistant runs on a cron schedule.
49|# Default: every 30 minutes, 7 AM to 11 PM.
50|cron:
51|  schedule: "*/30 7-23 * * *"                    # Every 30 min, hours 7-23
52|  enabled: true
53|  # To disable cron ticks temporarily:
54|  # enabled: false
55|
56|# --- Panel Session -----------------------------------------------------------
57|# The web panel where the assistant renders UI blocks.
58|panel:
59|  enabled: true
60|  port: 3000                                     # Panel web UI port
61|  host: localhost                                # Bind address
62|  # session_id: <auto-generated>                 # Created on first run
63|
64|# --- Vault Settings ----------------------------------------------------------
65|# Path to your Obsidian vault (or any markdown directory).
66|vault:
67|  path: <your-vault-path>                        # e.g. /home/user/obsidian-vault/
68|  # The assistant reads/writes:
69|  #   Ops/one-thing.md          — daily focus
70|  #   Journal/2026/daily/       — daily journals
71|  #   Ops/entities/projects/    — project entity cards
72|  #   Ops/feedback/             — feedback loop data
73|  #   Ops/context-modes/        — time-of-day mode rules
74|  #   Ops/habits/lifecycle/     — habit tracking
75|
76|# --- Calendar Settings -------------------------------------------------------
77|# Google Calendar integration (requires OAuth setup).
78|calendar:
79|  enabled: true
80|  # calendar_id: <your-calendar-id>              # Your Google Calendar ID
81|  # credentials_path: <path-to-credentials.json>  # OAuth credentials file
82|
83|# --- Tone & Behavior ---------------------------------------------------------
84|behavior:
85|  emoji: false                                   # No emoji in responses
86|  em_dash: false                                 # No em-dashes
87|  prose_line_limit: 10                           # Max prose lines before forcing blocks
88|  proactive_max_per_day: 5                       # Max proactive surfaces per day
89|  proactive_cutoff_hour: 22                      # No proactive after this hour
90|